{
  "name": "kiducode-website",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:css\" \"npm:dev:astro\"",
    "dev:astro": "astro dev",
    "dev:css": "tailwindcss -i ./src/styles/global.css -o ./public/styles.css --watch",
    "build": "npm run build:css && astro build",
    "build:css": "tailwindcss -i ./src/styles/global.css -o ./public/styles.css --minify",
    "preview": "astro preview"
  },
  "dependencies": {
    "@astrojs/sitemap": "^3.7.2",
    "astro": "^6.3.7",
    "autoprefixer": "^10.5.0",
    "concurrently": "^9.2.1",
    "express": "^5.2.1",
    "postcss": "^8.5.15",
    "tailwindcss": "^3.4.17"
  }
}
