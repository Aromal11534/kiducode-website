---
interface Props {
  command?: string;
  lines?: string[];
}

const {
  command = '$ kiducode --manglish "oru react login page undakku, username password validation venam"',
  lines = [
    "KiduCode:",
    "Normalized task:",
    "Create a React login page with username and password validation.",
    "",
    "Actions:",
    "✓ Created LoginPage.tsx",
    "✓ Added form validation",
    "✓ Updated routing",
    "✓ Generated summary",
  ],
} = Astro.props;
---

<div class="terminal-demo surface-panel overflow-hidden rounded-xl">
  <div class="flex items-center justify-between gap-4 border-b border-white/8 px-5 py-4">
    <div class="flex items-center gap-2">
      <span class="h-3 w-3 rounded-full bg-rose-400/80"></span>
      <span class="h-3 w-3 rounded-full bg-amber-400/80"></span>
      <span class="h-3 w-3 rounded-full bg-brand/80"></span>
    </div>
    <span class="font-mono text-xs uppercase tracking-[0.24em] text-slate-400">
      terminal demo
    </span>
  </div>
  <div class="space-y-4 px-5 py-6 font-mono text-sm leading-7 text-slate-200">
    <p class="terminal-command overflow-x-auto text-brand-soft">{command}</p>
    <div class="terminal-output space-y-1">
      {lines.map((line, i) => (
        <p
          class:list={[
            "terminal-line",
            line === "" && "h-3",
            line.startsWith("✓") && "text-slate-100",
          ]}
          style={`--line-index: ${i};`}
        >
          {line}
        </p>
      ))}
    </div>
    <span class="terminal-cursor inline-block h-4 w-2 bg-brand-soft/70"></span>
  </div>
</div>

<style>
  /* Typing animation for the command line */
  .terminal-command {
    overflow: hidden;
    white-space: nowrap;
    border-right: 2px solid rgba(189, 248, 188, 0.7);
    width: 0;
    animation:
      typing 2.2s steps(80, end) 0.5s forwards,
      blink-caret 0.75s step-end 6;
  }

  @keyframes typing {
    from { width: 0; }
    to { width: 100%; border-right-color: transparent; }
  }

  @keyframes blink-caret {
    50% { border-right-color: transparent; }
  }

  /* Sequential line reveal */
  .terminal-line {
    opacity: 0;
    transform: translateY(4px);
    animation: revealLine 0.3s ease forwards;
    animation-delay: calc(2.8s + var(--line-index) * 0.15s);
  }

  @keyframes revealLine {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* Blinking cursor at the end */
  .terminal-cursor {
    opacity: 0;
    animation: cursorBlink 1s step-end infinite;
    animation-delay: 4.5s;
  }

  @keyframes cursorBlink {
    0%, 100% { opacity: 0; }
    50% { opacity: 1; }
  }
</style>
