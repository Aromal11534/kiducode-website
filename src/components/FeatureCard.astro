---
interface Props {
  title: string;
  description: string;
  icon?: string;
}

const { title, description, icon = ">" } = Astro.props;
---

<article class="group surface-muted rounded-xl p-6 transition-all duration-200 hover:border-white/20 hover:bg-[#0c0c0c]">
  <div class="mb-4 inline-flex h-10 w-10 items-center justify-center rounded-lg border border-white/10 bg-white/5 font-mono text-sm text-slate-300 transition-colors duration-200 group-hover:border-white/20 group-hover:text-white">
    {icon}
  </div>
  <h3 class="text-base font-semibold text-white">{title}</h3>
  <p class="mt-2 text-sm leading-6 text-slate-400">{description}</p>
</article>
