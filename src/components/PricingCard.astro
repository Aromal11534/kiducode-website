---
interface Props {
  tier: string;
  description: string;
  features: string[];
}

const { tier, description, features } = Astro.props;
---

<article class="group surface-panel rounded-xl p-8 transition-all duration-200 hover:border-white/20 hover:bg-[#0c0c0c]">
  <div class="flex items-center justify-between gap-4">
    <h3 class="text-xl font-semibold text-white">{tier}</h3>
    <span class="rounded-md border border-white/10 bg-white/5 px-2.5 py-1 text-[10px] font-medium uppercase tracking-widest text-slate-300 transition-colors duration-200 group-hover:border-white/20 group-hover:text-white">
      Planned
    </span>
  </div>
  <p class="mt-4 text-sm leading-7 text-slate-400">{description}</p>
  <ul class="mt-8 space-y-4 text-sm text-slate-300">
    {features.map((feature) => (
      <li class="flex items-start gap-3">
        <span class="mt-0.5 font-mono text-white/40 transition-colors duration-200 group-hover:text-white/60">+</span>
        <span>{feature}</span>
      </li>
    ))}
  </ul>
</article>
