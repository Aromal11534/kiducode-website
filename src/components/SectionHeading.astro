---
interface Props {
  eyebrow?: string;
  title: string;
  description?: string;
  align?: "left" | "center";
}

const {
  eyebrow,
  title,
  description,
  align = "left",
} = Astro.props;
---

<div class:list={["max-w-3xl", align === "center" && "mx-auto text-center"]}>
  {eyebrow && <span class="eyebrow">{eyebrow}</span>}
  <h2 class="mt-4 text-3xl font-semibold tracking-tight text-white sm:text-4xl">
    {title}
  </h2>
  {description && (
    <p class="mt-4 text-base leading-7 text-slate-300 sm:text-lg">{description}</p>
  )}
</div>
