---
import Button from "../components/Button.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Page Not Found — KiduCode"
  description="The page you're looking for doesn't exist."
>
  <section class="section-grid flex min-h-[70vh] flex-col items-center justify-center py-32 text-center lg:py-48">
    <div class="inline-flex h-20 w-20 items-center justify-center rounded-2xl border border-white/10 bg-white/5 mb-8">
      <span class="font-mono text-3xl text-brand-soft">404</span>
    </div>

    <h1 class="page-title">Page not found</h1>
    <p class="page-copy mt-4 text-center">
      The page you're looking for doesn't exist or has been moved.
    </p>

    <div class="mt-10 flex flex-wrap justify-center gap-4">
      <Button href="/">Back to Home</Button>
      <Button href="/docs" variant="secondary">Read the Docs</Button>
    </div>

    <div class="surface-muted mt-16 rounded-xl p-6 max-w-md">
      <p class="font-mono text-sm text-slate-400">
        <span class="text-brand-soft">$</span> kiducode --find "missing page"
      </p>
      <p class="mt-2 font-mono text-sm text-slate-500">
        Error: No route matches the requested path.
      </p>
    </div>
  </section>
</BaseLayout>
