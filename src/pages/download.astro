---
import Button from "../components/Button.astro";
import SectionHeading from "../components/SectionHeading.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { site } from "../data/site";

const platforms = [
  {
    name: "macOS",
    commands: [
      "curl -fsSL https://kiducode.com/install | bash",
      "brew install kiducode/tap/kiducode",
    ],
  },
  {
    name: "Linux",
    commands: [
      "curl -fsSL https://kiducode.com/install | bash",
      "npm i -g kiducode",
    ],
  },
  {
    name: "Windows",
    commands: [
      "npm i -g kiducode",
      "git clone https://github.com/kiducode/kiducode.git",
      "cd kiducode",
    ],
  },
];
---

<BaseLayout
  title="Download KiduCode"
  description="Download page for KiduCode with placeholder install commands for macOS, Linux, and Windows, plus build-from-source guidance."
>
  <section class="section-grid py-16 lg:py-24">
    <SectionHeading
      eyebrow="Download"
      title="Download KiduCode"
      description="Installation commands are shown early so teams can plan around the future CLI rollout, but they should be treated as placeholders until the first public release."
    />
  </section>

  <section class="section-grid pb-8">
    <div class="surface-panel rounded-[28px] p-6">
      <p class="font-mono text-sm text-brand-soft">Primary install commands</p>
      <div class="mt-4 space-y-3 font-mono text-sm text-slate-200">
        <pre class="overflow-x-auto rounded-2xl border border-white/8 bg-black/30 px-4 py-3">curl -fsSL https://kiducode.com/install | bash</pre>
        <pre class="overflow-x-auto rounded-2xl border border-white/8 bg-black/30 px-4 py-3">npm i -g kiducode</pre>
      </div>
      <p class="mt-4 text-sm text-slate-400">
        The final install commands will be updated after the first public package
        release.
      </p>
    </div>
  </section>

  <section class="section-grid py-12">
    <div class="grid gap-5 lg:grid-cols-3">
      {platforms.map((platform) => (
        <article class="surface-panel rounded-[28px] p-6">
          <h2 class="text-xl font-semibold text-white">{platform.name}</h2>
          <div class="mt-5 space-y-3">
            {platform.commands.map((command) => (
              <pre class="overflow-x-auto rounded-2xl border border-white/8 bg-black/25 px-4 py-3 font-mono text-sm text-slate-200">{command}</pre>
            ))}
          </div>
        </article>
      ))}
    </div>
  </section>

  <section class="section-grid py-12">
    <div class="grid gap-5 lg:grid-cols-[0.9fr_1.1fr]">
      <article class="surface-panel rounded-[28px] p-6">
        <h2 class="text-xl font-semibold text-white">GitHub source</h2>
        <p class="mt-3 text-sm leading-7 text-slate-300">
          Until official package releases arrive, the source repository is the
          most transparent way to evaluate the project.
        </p>
        <div class="mt-6">
          <Button href={site.githubUrl} external={true}>View source</Button>
        </div>
      </article>
      <article class="surface-panel rounded-[28px] p-6">
        <h2 class="text-xl font-semibold text-white">Build from source</h2>
        <div class="mt-5 space-y-3">
          <pre class="overflow-x-auto rounded-2xl border border-white/8 bg-black/25 px-4 py-3 font-mono text-sm text-slate-200">git clone https://github.com/kiducode/kiducode.git</pre>
          <pre class="overflow-x-auto rounded-2xl border border-white/8 bg-black/25 px-4 py-3 font-mono text-sm text-slate-200">cd kiducode</pre>
        </div>
        <p class="mt-4 text-sm leading-7 text-slate-300">
          Full source build instructions will be documented once the public release
          pipeline is finalized.
        </p>
      </article>
    </div>
  </section>
</BaseLayout>
