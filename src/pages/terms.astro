---
import SectionHeading from "../components/SectionHeading.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="KiduCode Terms of Use — Open-Source AI Coding Agent Terms & Conditions"
  description="Terms of use for KiduCode, the Kerala-built open-source AI coding agent. Covers website usage, repository licensing, and future hosted service conditions."
>
  <section class="section-grid py-16 lg:py-24">
    <SectionHeading
      eyebrow="Terms"
      title="Terms of use placeholder"
      description="Formal terms will be published before any hosted product or commercial offering becomes available. For now, KiduCode is presented as an independent open-source project website."
      as="h1"
    />
  </section>

  <section class="section-grid pb-20">
    <article class="surface-panel rounded-[28px] p-6">
      <p class="text-sm leading-7 text-slate-300">
        Future terms will clarify website usage, repository licensing references,
        hosted-service conditions if introduced later, and boundaries around paid
        team or enterprise offerings.
      </p>
    </article>
  </section>
</BaseLayout>
