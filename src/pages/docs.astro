---
import Button from "../components/Button.astro";
import SectionHeading from "../components/SectionHeading.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { site } from "../data/site";

const sections = [
  {
    title: "Introduction",
    body:
      "KiduCode is a Kerala-built open-source AI coding agent focused on local-first developer workflows and future Manglish-friendly prompting.",
  },
  {
    title: "Installation",
    body:
      "Install commands shown here are placeholders until the first public package release. Source builds remain the safest early path.",
  },
  {
    title: "Quickstart",
    body:
      "Open a project, point KiduCode at your working directory, and use concise task prompts to explain, edit, refactor, or generate code.",
  },
  {
    title: "Commands",
    body:
      "Core CLI commands, prompt patterns, and output conventions will be documented here as the command surface stabilizes.",
  },
  {
    title: "Providers",
    body:
      "Planned provider support includes hosted APIs and local models, with room for community integrations and future marketplace patterns.",
  },
  {
    title: "Manglish Mode",
    body:
      "Manglish prompt detection and normalization are planned for an upcoming release, along with Malayalam-friendly explanation flows.",
  },
  {
    title: "Configuration",
    body:
      "This section will cover provider credentials, project rules, local settings, and future team-level controls.",
  },
  {
    title: "Plugins",
    body:
      "KiduCode is intended to stay extensible, with future plugin APIs for custom workflows, provider adapters, and templates.",
  },
  {
    title: "Contributing",
    body:
      "Open-source collaboration, issue triage, docs contributions, and upstream attribution guidance will live here.",
  },
  {
    title: "FAQ",
    body:
      "Common questions around local-first usage, supported providers, roadmap scope, and release plans will be added over time.",
  },
];
---

<BaseLayout
  title="KiduCode Docs — CLI Documentation, Installation & Manglish Mode Guide"
  description="Official documentation for KiduCode, the Kerala-built open-source AI coding agent. Covers installation, quickstart, CLI commands, Manglish Mode, provider configuration, plugins, and contributing."
>
  <section class="section-grid py-16 lg:py-24">
    <SectionHeading
      eyebrow="Docs"
      title="Documentation for the KiduCode CLI and workflow."
      description="This is a starter documentation landing page for the upcoming public release. It is structured to grow into a full docs experience without changing the information architecture later."
      as="h1"
    />
    <div class="mt-8 flex flex-wrap gap-3">
      <Button href="/download">Download</Button>
      <Button href={site.githubUrl} variant="secondary" external={true}>
        Source on GitHub
      </Button>
    </div>
  </section>

  <section class="section-grid pb-20">
    <div class="grid gap-5 md:grid-cols-2">
      {sections.map((section, index) => (
        <article class="surface-panel rounded-[28px] p-6">
          <p class="font-mono text-xs uppercase tracking-[0.24em] text-brand-soft">
            {String(index + 1).padStart(2, "0")}
          </p>
          <h2 class="mt-4 text-xl font-semibold text-white">{section.title}</h2>
          <p class="mt-3 text-sm leading-7 text-slate-300">{section.body}</p>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
