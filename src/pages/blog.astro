---
import SectionHeading from "../components/SectionHeading.astro";
import BaseLayout from "../layouts/BaseLayout.astro";

const posts = [
  "Introducing KiduCode",
  "Designing Manglish Mode",
  "Building an open-source AI coding agent from Kerala",
];
---

<BaseLayout
  title="KiduCode Blog — Updates, Engineering Notes & Manglish AI Development"
  description="Read the latest from KiduCode: product updates, engineering deep-dives, Manglish Mode development, and insights on building an open-source AI coding agent from Kerala."
>
  <section class="section-grid py-16 lg:py-24">
    <SectionHeading
      eyebrow="Blog"
      title="KiduCode Blog"
      description="This placeholder blog index is ready for launch notes, technical deep-dives, and updates on the Manglish-first product direction."
      as="h1"
    />
  </section>

  <section class="section-grid pb-20">
    <div class="grid gap-5 md:grid-cols-3">
      {posts.map((post, index) => (
        <article class="surface-panel rounded-[28px] p-6">
          <p class="font-mono text-xs uppercase tracking-[0.24em] text-brand-soft">
            Placeholder post {index + 1}
          </p>
          <h2 class="mt-4 text-xl font-semibold text-white">{post}</h2>
          <p class="mt-3 text-sm leading-7 text-slate-300">
            Draft content coming soon. This slot is reserved for future editorial
            publishing once the public launch timeline is locked.
          </p>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
