---
import SectionHeading from "../components/SectionHeading.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="KiduCode Privacy Policy — Local-First AI Coding Privacy Commitment"
  description="Privacy policy for KiduCode. KiduCode is designed as a local-first, privacy-first AI coding agent. No account system or backend forms are currently active."
>
  <section class="section-grid py-16 lg:py-24">
    <SectionHeading
      eyebrow="Privacy"
      title="Privacy policy placeholder"
      description="A detailed privacy policy will be added before any hosted product features launch. Until then, the website remains a static informational site with no account system or backend forms."
      as="h1"
    />
  </section>

  <section class="section-grid pb-20">
    <article class="surface-panel rounded-[28px] p-6">
      <p class="text-sm leading-7 text-slate-300">
        KiduCode aims for a privacy-first, local-first developer workflow.
        Website-level privacy terms will be expanded alongside any future hosted
        services, analytics decisions, or account-based features.
      </p>
    </article>
  </section>
</BaseLayout>
